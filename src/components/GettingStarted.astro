---
interface Props {
  content: {
    title: string
    intro: string
    ctaText: string
    ctaButton: string
    steps: Array<{
      number: string
      title: string
      description: string
      code: string | null
    }>
  }
}
const { content } = Astro.props
---

<section aria-label="Getting Started" id="getting-started" class="border-b border-zinc-800/50">
  <div class="max-w-5xl mx-auto px-6 py-16 sm:py-32">
    <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
      {content.title}
    </h2>
    <p class="mt-4 text-lg text-zinc-400 max-w-3xl">
      {content.intro}
    </p>

    <ol class="mt-16 space-y-12">
      {content.steps.map((step) => (
        <li class="flex gap-4 sm:gap-6 items-start">
          <span class="flex-shrink-0 w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-cyan-400/10 border border-cyan-400/20 flex items-center justify-center text-cyan-400 font-mono text-xs sm:text-sm font-bold">
            {step.number}
          </span>
          <div class="flex-1 pt-0 sm:pt-0.5 min-w-0">
            <h3 class="text-lg font-semibold text-white">{step.title}</h3>
            <p class="mt-1.5 text-zinc-400 leading-relaxed">{step.description}</p>
            {step.code && (
              <div class="mt-4 rounded-lg border border-zinc-800 bg-zinc-900/50 overflow-hidden">
                <pre class="px-3 sm:px-4 py-3 overflow-x-auto"><code class="text-xs sm:text-sm text-cyan-400 font-mono">{step.code}</code></pre>
              </div>
            )}
          </div>
        </li>
      ))}
    </ol>

  </div>
</section>
