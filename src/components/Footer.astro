---
const repoUrl = 'https://github.com/baltz/DIP'
const year = new Date().getFullYear()
---

<footer class="border-t border-zinc-800/50">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-6">
        <a href={`${import.meta.env.BASE_URL}`} class="text-white font-bold text-lg tracking-tight">
          DIP
        </a>
        <span class="text-zinc-600 text-sm">Deep Implementation Protocol</span>
      </div>

      <div class="flex items-center gap-6">
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors"
        >
          GitHub
        </a>
        <a
          href={`${repoUrl}/blob/main/templates`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors"
        >
          Templates
        </a>
        <a
          href={`${repoUrl}/blob/main/LICENSE`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors"
        >
          MIT License
        </a>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-zinc-800/50 text-center">
      <p class="text-xs text-zinc-600">
        &copy; {year} DIP — Deep Implementation Protocol. Open source under the MIT License.
      </p>
    </div>
  </div>
</footer>
