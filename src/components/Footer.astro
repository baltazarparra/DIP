---
interface Props {
  content: {
    tagline: string
    github: string
    templates: string
    license: string
    copyright: string
  }
}

const { content } = Astro.props
const repoUrl = 'https://github.com/baltazarparra/milestone'
const year = new Date().getFullYear()
const baseUrl = import.meta.env.BASE_URL
---

<footer class="border-t border-zinc-800/50">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-6">
        <a href={baseUrl} class="text-white font-bold text-lg tracking-tight">
          M
        </a>
        <span class="text-zinc-600 text-sm">{content.tagline}</span>
      </div>

      <div class="flex items-center gap-6">
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors"
        >
          {content.github}
        </a>
        <a
          href={`${repoUrl}/tree/main/templates`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors"
        >
          {content.templates}
        </a>
        <a
          href={`${repoUrl}/blob/main/LICENSE`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-zinc-500 hover:text-zinc-300 transition-colors"
        >
          {content.license}
        </a>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-zinc-800/50 text-center">
      <p class="text-xs text-zinc-600">
        &copy; {year} {content.copyright}
      </p>
    </div>
  </div>
</footer>
