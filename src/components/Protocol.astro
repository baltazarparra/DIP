---
interface Props {
  content: {
    title: string
    intro: string
    folderStructureLabel: string
    folderStructureCode: string
    steps: Array<{ number: string; title: string; description: string }>
    folderStructure: string
  }
}

const { content } = Astro.props
---

<section aria-label="The Protocol" class="border-b border-zinc-800/50">
  <div class="max-w-5xl mx-auto px-6 py-16 sm:py-32">
    <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
      {content.title}
    </h2>
    <p class="mt-4 text-lg text-zinc-400 max-w-3xl">
      {content.intro}
    </p>

    <ol class="mt-10 sm:mt-16 space-y-6 sm:space-y-8">
      {content.steps.map((step) => (
        <li class="flex gap-4 sm:gap-6 items-start">
          <span class="flex-shrink-0 w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-zinc-900 border border-zinc-800 flex items-center justify-center text-cyan-400 font-mono text-xs sm:text-sm font-bold">
            {step.number}
          </span>
          <div class="pt-0.5 sm:pt-1 min-w-0">
            <h3 class="text-lg font-semibold text-white">{step.title}</h3>
            <p class="mt-1.5 text-zinc-400 leading-relaxed">{step.description}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="mt-20">
      <h3 class="text-xl font-semibold text-white mb-6">{content.folderStructureLabel}</h3>
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/50 overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-zinc-800 bg-zinc-900">
          <span class="w-3 h-3 rounded-full bg-zinc-700" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full bg-zinc-700" aria-hidden="true"></span>
          <span class="w-3 h-3 rounded-full bg-zinc-700" aria-hidden="true"></span>
          <span class="ml-2 text-xs text-zinc-500 font-mono">{content.folderStructureCode}</span>
        </div>
        <pre class="p-4 sm:p-6 overflow-x-auto"><code class="text-xs sm:text-sm text-zinc-300 font-mono leading-relaxed">{content.folderStructure}</code></pre>
      </div>
    </div>
  </div>
</section>
