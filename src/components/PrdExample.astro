---
interface Props {
  content: {
    title: string
    intro: string
    fileName: string
    prdContent: string
  }
}

const { content } = Astro.props
---

<section aria-label="PRD Example" class="border-b border-zinc-800/50">
  <div class="max-w-5xl mx-auto px-6 py-16 sm:py-32">
    <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
      {content.title}
    </h2>
    <p class="mt-4 text-lg text-zinc-400 max-w-3xl">
      {content.intro}
    </p>

    <div class="mt-12 rounded-xl border border-zinc-800 bg-zinc-900/50 overflow-hidden">
      <div class="flex items-center gap-2 px-4 py-3 border-b border-zinc-800 bg-zinc-900">
        <span class="w-3 h-3 rounded-full bg-zinc-700" aria-hidden="true"></span>
        <span class="w-3 h-3 rounded-full bg-zinc-700" aria-hidden="true"></span>
        <span class="w-3 h-3 rounded-full bg-zinc-700" aria-hidden="true"></span>
        <span class="ml-2 text-xs text-zinc-500 font-mono">{content.fileName}</span>
      </div>
      <pre class="p-4 sm:p-6 overflow-x-auto max-h-[500px] sm:max-h-[600px]"><code class="text-xs sm:text-sm text-zinc-300 font-mono leading-relaxed">{content.prdContent}</code></pre>
    </div>
  </div>
</section>
