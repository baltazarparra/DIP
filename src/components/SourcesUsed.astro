---
interface Props {
  content: {
    label: string
    sources: Array<{ title: string; url: string }>
  }
}

const { content } = Astro.props
---

<section aria-label="Sources Used" class="border-t border-zinc-900 bg-zinc-950">
  <div class="max-w-6xl mx-auto px-6 py-14 sm:py-16">
    <p class="text-[10px] uppercase tracking-[0.2em] text-zinc-500">
      {content.label}
    </p>

    <p class="mt-4 text-[11px] sm:text-xs leading-relaxed text-zinc-500 max-w-6xl">
      {content.sources.map((source, index) => (
        <>
          <a
            href={source.url}
            target="_blank"
            rel="noopener noreferrer"
            class="underline decoration-zinc-600 underline-offset-2 hover:text-zinc-300 transition-colors"
          >
            {source.title}
          </a>
          <span class="text-zinc-600"> ({source.url})</span>
          {index < content.sources.length - 1 && <span class="text-zinc-700"> · </span>}
        </>
      ))}
    </p>
  </div>
</section>
