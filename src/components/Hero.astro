---
const repoUrl = 'https://github.com/baltz/DIP'
---

<header class="relative overflow-hidden border-b border-zinc-800/50">
  <div class="absolute inset-0 bg-gradient-to-b from-cyan-950/20 via-transparent to-transparent pointer-events-none" aria-hidden="true"></div>

  <nav class="relative max-w-5xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href={`${import.meta.env.BASE_URL}`} class="text-white font-bold text-xl tracking-tight">
      DIP
    </a>
    <div class="flex items-center gap-6">
      <a href="#getting-started" class="text-sm text-zinc-400 hover:text-white transition-colors">
        Get Started
      </a>
      <a
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-zinc-400 hover:text-white transition-colors flex items-center gap-1.5"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
        </svg>
        GitHub
      </a>
    </div>
  </nav>

  <div class="relative max-w-5xl mx-auto px-6 pt-20 pb-24 sm:pt-28 sm:pb-32 text-center">
    <p class="inline-block text-xs font-semibold tracking-widest uppercase text-cyan-400 mb-6 border border-cyan-400/20 rounded-full px-4 py-1.5 bg-cyan-400/5">
      Open Protocol
    </p>

    <h1 class="text-5xl sm:text-7xl font-extrabold text-white tracking-tight leading-[1.1]">
      Deep Implementation<br />Protocol
    </h1>

    <p class="mt-6 text-lg sm:text-xl text-zinc-400 max-w-2xl mx-auto leading-relaxed">
      A structured, document-driven protocol for agentic software development.
      Organize complex projects into milestones, phases, and PRDs — giving AI coding agents
      the context they need to build with precision.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#getting-started"
        class="inline-flex items-center px-6 py-3 text-sm font-semibold text-zinc-950 bg-cyan-400 rounded-lg hover:bg-cyan-300 transition-colors"
      >
        Get Started
      </a>
      <a
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-zinc-300 border border-zinc-700 rounded-lg hover:border-zinc-500 hover:text-white transition-colors"
      >
        View on GitHub
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"></path>
        </svg>
      </a>
    </div>
  </div>
</header>
